### GitIgnore for OmniRoute ###

# General
.DS_Store
*.log

# Environments
.env
.env.local
.env.production
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/

# IDEs and Editors
.vscode/
.idea/
*.swp
*.swo

# Backend (Django/Python)
__pycache__/
*.py[cod]
*$py.class
*.so
backend/db.sqlite3
backend/db.sqlite3-journal
backend/media/
backend/staticfiles/
.pytest_cache/
htmlcov/
.tox/
.coverage
.coverage.*
nosetests.xml
coverage.xml
*.egg-info/
.eggs/
build/
dist/

# Frontend (Node / JS)
node_modules/
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.npm/
frontend/.eslintcache
frontend/.stylelintcache
frontend/.next/
frontend/out/
frontend/coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Infra / Terraform (if applicable)
.terraform/
*.tfstate
*.tfstate.backup

# Testing
coverage/

# Misc
*.orig
*.rej
